C8,          HEX 6B5A     / blanco
ImpVal,      DEC 0        / variable aux ImprimirNum
ImpDig,      DEC 0        / variable aux ImprimirNum
ImpFlag,     DEC 0        / variable aux ImprimirNum
Ascii0,      DEC 48       / codigo ASCII de '0'
Cien,        DEC 100
Diez,        DEC 10
/ --- Variables nuevas ---
BASE,       DEC 0
CAT,        DEC 0
MinePtr,    HEX 400
MineStart,  HEX 400
BotLF,      HEX 400
BotCol,     DEC 0
CurCol,     DEC 0
MinaVal,    DEC -1
MineMax,    HEX 500
MineWrap,   HEX 100
Quince,     DEC 15
CntSegInicial, DEC 247          / fijar según forma antes de ensamblar
/ ── Subrutina ImprimirNum: imprime Movimientos en ASCII ─────────────
/ Imprime hasta 3 digitos (0-999). No imprime ceros a la izquierda.
/ Usa variables: ImpVal, ImpDig, ImpFlag
ImprimirNum, HEX 0
        Load  Movimientos
        Store ImpVal       / ImpVal = Movimientos
        Clear
        Store ImpFlag      / ImpFlag=0: aun no imprimimos ningun digito
/ ── Centenas ────────────────────────────────────────────────────────
        Clear
        Store ImpDig       / ImpDig = 0 (contador de centenas)
ImpC,   Load  ImpVal
        Subt  Cien
        SkipCond 800       / AC > 0 → ImpVal >= 100
        Jump  ImpCFin      / ImpVal < 100 → fin centenas
        Store ImpVal       / ImpVal -= 100
        Load  ImpDig
        Add   Uno
        Store ImpDig
        Jump  ImpC
ImpCFin, Load  ImpDig
        SkipCond 400       / ImpDig == 0 → no imprimir
        Jump  ImpCSkip     / ImpDig != 0 → imprimir centena
        Jump  ImpD         / ImpDig == 0 → saltar a decenas
ImpCSkip, Load  ImpDig
        Add   Ascii0       / digito + '0'
        Output
        LoadImmi 1
        Store ImpFlag      / ya imprimimos algo
/ ── Decenas ─────────────────────────────────────────────────────────
ImpD,   Clear
        Store ImpDig
ImpD2,  Load  ImpVal
        Subt  Diez
        SkipCond 800       / AC > 0 → ImpVal >= 10
        Jump  ImpDFin
        Store ImpVal
        Load  ImpDig
        Add   Uno
        Store ImpDig
        Jump  ImpD2
ImpDFin, Load  ImpFlag
        SkipCond 400       / ImpFlag == 0 → solo imprimir si ImpDig != 0
        Jump  ImpDForce    / ImpFlag != 0 → imprimir siempre
        Load  ImpDig
        SkipCond 400       / ImpDig == 0 → saltar
        Jump  ImpDSkip
        Jump  ImpU
ImpDForce, Load  ImpDig
        Add   Ascii0
        Output
        Jump  ImpU2
ImpDSkip, Load  ImpDig
        Add   Ascii0
        Output
        LoadImmi 1
        Store ImpFlag
/ ── Unidades ────────────────────────────────────────────────────────
ImpU,   Load  ImpVal      / lo que queda son unidades
ImpU2,  Add   Ascii0
        Output
        JumpI ImprimirNum

